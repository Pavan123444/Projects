class Node:
    def __init__(self, data):
        self.data = data
        self.left = None
        self.right = None
# create root node
root = Node(10)
# insert left and right
root.left = Node(20)
root.right = Node(30)
# insert more nodes
root.left.left = Node(40)
root.left.right = Node(50)
print("Root:", root.data)
print("Left child:", root.left.data)
print("Right child:", root.right.data)
